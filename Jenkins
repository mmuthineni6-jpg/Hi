pipeline {
    agent any

    environment {
        APP_NAME = "my-app"
        BUILD_NUMBER = "${env.BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    triggers {
        // Optional: poll SCM (or use webhook instead)
        // pollSCM('H/5 * * * *')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "Building ${APP_NAME}..."
                // Example:
                sh 'echo Build step here'
            }
        }

        stage('Test') {
            steps {
                echo "Running tests..."
                sh 'echo Test step here'
            }
        }

        stage('Code Quality') {
            steps {
                echo "Code quality checks..."
                // Example: SonarQube / linting
            }
        }

        stage('Package') {
            steps {
                echo "Packaging application..."
                sh 'echo Package step here'
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "Deploying to production..."
                sh 'echo Deploy step here'
            }
        }
    }

    post {
        success {
            echo "✅ Build succeeded!"
        }
        failure {
            echo "❌ Build failed!"
        }
        always {
            echo "📦 Cleaning workspace..."
            cleanWs()
        }
    }
}
